APP_NAME=LockNear
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────
# Production: LOG_CHANNEL=stderr, LOG_LEVEL=warning
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: sqlite
# Production (Neon): DB_CONNECTION=pgsql + DATABASE_URL from Neon dashboard
#   DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_CONNECTION=sqlite
# DB_URL=
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

# ─── Session / Cache ─────────────────────────────────────────────────────────
# Production: SESSION_DRIVER=redis, CACHE_STORE=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database

# ─── Queue / Horizon ─────────────────────────────────────────────────────────
# Local: database   |   Production: redis (Upstash or Railway Redis)
# Upstash: REDIS_URL=rediss://default:token@host.upstash.io:6379
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
HORIZON_PATH=horizon
HORIZON_ALLOWED_EMAILS=admin@locknear.com

# ─── Redis (Upstash serverless OR Railway Redis plugin) ──────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Production (Railway Redis plugin) — set REDIS_URL from Railway variable reference:
# REDIS_URL=${{Redis.REDIS_URL}}
# DB separation is handled by database.php: queue→DB0, cache→DB1
# REDIS_CLIENT=phpredis

# ─── Cloudflare R2 (file/logo storage) ───────────────────────────────────────
# Cloudflare dashboard → R2 → Create bucket → Manage R2 API Tokens
# Set FILESYSTEM_DISK=r2 in production
# AWS_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# AWS_URL=https://cdn.locknear.com  (custom domain on R2 bucket)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=locknear
AWS_ENDPOINT=
AWS_URL=https://cdn.locknear.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Mail (Resend primary → Cloudflare Email fallback → log) ─────────────────
# Production: MAIL_MAILER=failover
# Resend: create API key at resend.com, add locknear.com domain
# Cloudflare Email Sending: enable via Cloudflare dashboard → Email → Email Sending
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@locknear.com"
MAIL_FROM_NAME="LockNear"
RESEND_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SUPPORT_INBOX=support@locknear.com

# ─── Meilisearch (company full-text search) ──────────────────────────────────
# Local: docker compose up -d (docker-compose.yml)
# Production: Meilisearch Cloud (cloud.meilisearch.com) free tier
# After deploy: php artisan locknear:setup-meilisearch
SCOUT_DRIVER=collection
SCOUT_QUEUE=true
SCOUT_PREFIX=locknear_
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# ─── Reverb (real-time WebSocket — dispatch + tracking) ──────────────────────
# Production: separate Railway service running railway/run-reverb.sh
# REVERB_HOST = public hostname of the reverb Railway service (e.g. reverb.locknear.com)
REVERB_APP_ID=locknear
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://locknear.com
APP_PROVIDER_URL=https://app.locknear.com
APP_LOCKNEAR_URL=http://localhost:3000
CUSTOMER_AUTH_REDIRECT_HOSTS=locknear.com,localhost,127.0.0.1
BUSINESS_AUTH_REDIRECT_HOSTS=app.locknear.com,localhost,127.0.0.1
BUSINESS_APP_URL=http://localhost:3000

# ─── Google OAuth (customer sign-in on locknear.com) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/customer/auth/google/callback"
# Also add in Google Console: ${APP_URL}/api/auth/google/callback

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=locknear.com,app.locknear.com,localhost,localhost:4321,localhost:3000,127.0.0.1

# ─── API key (Astro ↔ Laravel server-to-server) ──────────────────────────────
# Must match astro-locknear LARAVEL_API_KEY env var
ASTRO_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_LEAD_BILLING_ENABLED=false
LOCKNEAR_LEAD_BILLING_ENABLED=false
LOCKNEAR_DISPATCH_REQUIRE_SUBSCRIPTION=false
LOCKNEAR_COMMISSION_RATE=0.20
LOCKNEAR_GHOST_DISPATCH_ENABLED=true
LOCKNEAR_GHOST_DISPATCH_LIMIT=20
# Package price IDs (run: php artisan db:seed --class=PackageSeeder)
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# ─── Twilio (SMS — dispatch + customer notifications) ────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Presence / dispatch timing ──────────────────────────────────────────────
LOCKNEAR_PRESENCE_ONLINE_MINUTES=1
LOCKNEAR_PRESENCE_AWAY_MINUTES=2
LOCKNEAR_PRESENCE_HEARTBEAT_SECONDS=30
LOCKNEAR_DISPATCH_ACCEPT_MINUTES=30
LOCKNEAR_DISPATCH_FEE_CENTS=3900
LOCKNEAR_DISPATCH_REQUIRE_SUBSCRIPTION=true
